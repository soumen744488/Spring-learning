spring.application.name=jpaTuts
# Connection URL (Default port is 5432)
spring.datasource.url=jdbc:postgresql://localhost:5432/testDb
spring.datasource.username=postgres
spring.datasource.password=1001

# Hibernate settings (Optional but recommended)
# 'update' automatically creates/updates tables based on your Java entities
spring.jpa.hibernate.ddl-auto=create
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

